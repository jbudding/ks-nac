{
  "rules": [
    {
      "name": "admin-access",
      "description": "Full access for administrators",
      "enabled": true,
      "condition": {
        "type": "user_in_group",
        "group": "admins"
      },
      "action": {
        "type": "accept",
        "filter_id": "ADMIN-ACL",
        "attributes": {}
      }
    },
    {
      "name": "employee-access",
      "description": "Standard employee access",
      "enabled": true,
      "condition": {
        "type": "user_in_group",
        "group": "employees"
      },
      "action": {
        "type": "accept",
        "filter_id": "EMPLOYEE-ACL",
        "attributes": {}
      }
    },
    {
      "name": "allow-guest-ssid",
      "description": "Allow guests on guest SSID with restricted access",
      "enabled": true,
      "condition": {
        "type": "all",
        "conditions": [
          {
            "type": "attribute",
            "attribute": "Called-Station-Id",
            "operator": "contains",
            "value": "guest"
          },
          {
            "type": "attribute",
            "attribute": "User-Name",
            "operator": "equals",
            "value": "7a30c2ad283a"
          }
        ]
      },
      "action": {
        "type": "accept",
        "filter_id": "GUEST-ACL",
        "attributes": {
          "Session-Timeout": "3600"
        }
      }
    },
    {
      "name": "mab-printers",
      "description": "Printer access via MAB",
      "enabled": true,
      "condition": {
        "type": "all",
        "conditions": [
          {
            "type": "is_mab"
          },
          {
            "type": "user_in_group",
            "group": "printers"
          }
        ]
      },
      "action": {
        "type": "accept",
        "filter_id": "PRINTER-ACL",
        "attributes": {}
      }
    },
    {
      "name": "mab-phones",
      "description": "Phone access via MAB",
      "enabled": true,
      "condition": {
        "type": "all",
        "conditions": [
          {
            "type": "is_mab"
          },
          {
            "type": "user_in_group",
            "group": "phones"
          }
        ]
      },
      "action": {
        "type": "accept",
        "filter_id": "PHONE-ACL",
        "attributes": {}
      }
    },
    {
      "name": "mab-iot",
      "description": "IoT device access via MAB",
      "enabled": true,
      "condition": {
        "type": "all",
        "conditions": [
          {
            "type": "is_mab"
          },
          {
            "type": "user_in_group",
            "group": "iot"
          }
        ]
      },
      "action": {
        "type": "accept",
        "filter_id": "IOT-ACL",
        "attributes": {
          "Session-Timeout": "86400"
        }
      }
    },
    {
      "name": "default-reject",
      "description": "Reject all unmatched requests",
      "enabled": true,
      "condition": {
        "type": "always"
      },
      "action": {
        "type": "reject"
      }
    }
  ]
}
